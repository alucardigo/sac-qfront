# ─── Microsoft Graph (Entra App Registration, fluxo app-only client_credentials) ───
# Permissões de aplicação: Mail.ReadWrite, Mail.Send (admin consent). NÃO commitar valores reais.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX=sac@bellube.com.br
GRAPH_FOLDERS=Inbox,Archive,SentItems

# ─── QFront / Chatwoot (devise-token-auth) ───
# Extraia os 3 tokens do cookie cw_d_session_info de um usuário admin logado (ver docs/GUIA_DESENVOLVEDOR.md).
QFRONT_BASE=https://<sua-instancia-chatwoot>/api/v1/accounts/<account_id>
QFRONT_ACCESS_TOKEN=
QFRONT_CLIENT=
QFRONT_UID=
QFRONT_INBOX_ID=          # id da caixa do canal sac@ (Channel::Api)
QFRONT_HIST_INBOX_ID=     # id da caixa de histórico importado (opcional)

# ─── Comportamento da ponte ───
TRIAGE_TEAM_ID=1          # time default p/ conversas sem motivo claro
AUTO_ACK=true             # auto-resposta de confirmação com protocolo
POLL_MS=20000             # intervalo de polling do Graph (ms)
OUTBOUND_ENABLED=false    # habilita envio sac@ -> cliente (ligar após validar)
OUTBOUND_WHITELIST=       # e-mails permitidos p/ envio; vazio=nenhum, '*'=todos
