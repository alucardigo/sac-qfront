# ---- Neppo Chat API (credencial gerada em Integrações > Neppo Token API) ----
NEPPO_API_BASE=https://api.neppo.com.br
NEPPO_CONSUMER_KEY=        # "Chave do consumidor"
NEPPO_CONSUMER_SECRET=     # "Senha do consumidor"
NEPPO_USER=                # "Usuário" (ex.: bellube_cltkk4xeg59cmuen)
NEPPO_PASS=                # "Senha"
NEPPO_CHANNEL=WHATSAPP
NEPPO_GROUP_NAME=Atendimento   # grupo de atendimento (confirmar em Serviços)
NEPPO_GROUP_CONF_ID=1          # id do grupo (confirmar)
NEPPO_USER_ID=0                # id do usuário Neppo p/ envio (confirmar)

# ---- QFront / Chatwoot ----
QFRONT_BASE=https://chat-bellube.megleo.com.br/api/v1/accounts/2
QFRONT_TOKEN=              # "Token de acesso" do perfil (Configurações do Perfil > Token de acesso)
QFRONT_INBOX_ID=2         # caixa API dedicada ao WhatsApp (criar "WhatsApp (Neppo)" ou usar a id 2)

# ---- Comportamento ----
POLL_MS=15000
INBOUND_ONLY=true         # Fase 1: só espelha WhatsApp->QFront (não envia ao cliente)
OUTBOUND_ENABLED=false    # Fase 2: habilitar resposta QFront->WhatsApp após validação
